app.put('/api/admin/weekly-menu/sync', async (req, res) => {
    const { start_date, end_date, menu_items } = req.body;
    
    try {
        // 1. Clear out the existing schedule for this exact date range
        await db.promise().query("DELETE FROM daily_menu WHERE serve_date BETWEEN ? AND ?", [start_date, end_date]);

        // 2. If the Warden deleted everything and saved an empty week, just return success
        if (!menu_items || menu_items.length === 0) {
            return res.json({ success: true, message: "Menu cleared and saved." });
        }

        // 3. Build a bulk insert array
        const values = menu_items.map(item => [
            item.serve_date, 
            item.meal_type, 
            item.dish_id, 
            'Approved' // Everything saved through this button is instantly approved
        ]);

        // 4. Bulk insert the new draft into the database
        const insertSql = "INSERT INTO daily_menu (serve_date, meal_type, dish_id, status) VALUES ?";
        await db.promise().query(insertSql, [values]);

        res.json({ success: true, message: "Weekly menu saved and approved successfully!" });
    } catch (err) {
        console.error("Error syncing weekly menu:", err);
        res.status(500).json({ error: "Failed to save weekly menu" });
    }
});


